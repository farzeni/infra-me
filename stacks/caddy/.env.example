# Caddyfile to mount.
# Local dev: Caddyfile.local (tls internal, no Cloudflare required)
# Production: Caddyfile (Cloudflare DNS-01, requires CF_API_TOKEN)
CADDYFILE=Caddyfile.local

# Cloudflare API token — Zone:DNS:Edit permission for askalotl.net
# Required only when CADDYFILE=Caddyfile (production)
# Create at: Cloudflare Dashboard → My Profile → API Tokens
CF_API_TOKEN=
